---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

const recetas = await getCollection('recetas');
---

<BaseLayout title="Indito — Recetas de Olga">
  <Nav />
  
  <main>
    <section class="hero">
      <span class="hero__label">Recetas de familia</span>
      <h1>Las recetas<br />de mamá</h1>
      <p class="hero__subtitle">Sabores de la infancia transmitidos de generación en generación. Las recetas que Olga cocinaba en casa.</p>
    </section>

    <section class="recipes-section">
      <div class="container">
        <div class="recipes-section__header">
          <h2 class="section-title">Recetas</h2>
          <span class="section-count">{recetas.length} receta{recetas.length !== 1 ? 's' : ''}</span>
        </div>
        <div class="recipes-grid">
          {recetas.map((receta) => (
            <RecipeCard
              title={receta.data.title}
              slug={receta.slug}
              image={receta.data.image}
              category={receta.data.category}
              description={receta.data.description}
            />
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
